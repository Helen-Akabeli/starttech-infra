[
  {
    "AlarmName": "starttech-backend-high-cpu",
    "AlarmDescription": "Triggers scale-out if backend CPU exceeds 80%",
    "MetricName": "CPUUtilization",
    "Namespace": "AWS/EC2",
    "Statistic": "Average",
    "Period": 300,
    "EvaluationPeriods": 2,
    "Threshold": 80.0,
    "ComparisonOperator": "GreaterThanOrEqualToThreshold",
    "Dimensions": [
      {
        "Name": "AutoScalingGroupName",
        "Value": "starttech-asg"
      }
    ]
  },
  {
    "AlarmName": "starttech-backend-unhealthy-hosts",
    "AlarmDescription": "Triggers if targets fail target group health checks",
    "MetricName": "UnHealthyHostCount",
    "Namespace": "AWS/ApplicationELB",
    "Statistic": "Average",
    "Period": 60,
    "EvaluationPeriods": 1,
    "Threshold": 1.0,
    "ComparisonOperator": "GreaterThanOrEqualToThreshold"
  }
]
